@startuml User Business Flow

skinparam ActivityBackgroundColor #F0F4FF
skinparam ActivityBorderColor #4A6FA5
skinparam ActivityDiamondBackgroundColor #FFF8E1
skinparam ActivityDiamondBorderColor #E6A817
skinparam ArrowColor #4A6FA5
skinparam NoteBackgroundColor #FFEEEE
skinparam NoteBorderColor #CC4444

title 3xui-shop — Пользовательский бизнес-флоу

|Пользователь|
start
:Нажимает /start;

|Система|
if (Новый пользователь?) then (да)

  if (command.args передан?) then (да)
    if (args.isdigit()?) then (реферальная ссылка)
      :Ищет реферера по tg_id;
      if (Реферер найден\nи не сам пользователь?) then (да)
        :Создаёт Referral запись;
        note right
          ⚠️ РИСК: A->B + B->A
          круговая схема (P1)
        end note
      else (нет)
        :Пропускает реф-атрибуцию;
      endif
    else (инвайт-хэш)
      :Ищет Invite по hash;
      if (Инвайт активен?) then (да)
        :Записывает source_invite\nИнкрементирует clicks;
        note right
          ⚠️ РИСК: накрутка
          мульти-аккаунтами (P2)
        end note
      else (нет)
        :Пропускает инвайт;
      endif
    endif
  else (нет args)
    :Продолжает без атрибуции;
  endif

  :Показывает главное меню;

  if (Реферальный триал\nдоступен?) then (да)
    note right
      ⚠️ ИСПРАВЛЕНО: race
      condition — условный
      UPDATE WHERE is_trial_used=False
    end note
    :Начисляет referred_trial_period дней\nОтмечает referred_rewarded_at;
    :Сообщение «Триал активирован»;
  else (нет)
    if (Обычный триал\nдоступен?) then (да)
      :Начисляет trial_period дней\nОтмечает is_trial_used=True;
      :Сообщение «Триал активирован»;
    else (нет)
      :Просто главное меню;
    endif
  endif

  :Запускает онбординг — выбор устройства;

  |Пользователь|
  if (Выбирает устройство?) then (Android/iPhone/Mac/Windows)
    |Система|
    :Сохраняет device в User;
    :Показывает запрос email;

    |Пользователь|
    if (Вводит email?) then (вводит текст)
      |Система|
      if (Email валидный?) then (да)
        :Сохраняет email\n+ONBOARDING_BONUS_DAYS дней;
        :«Бонус начислен»;
      else (нет)
        :«Введите корректный email»;
      endif
    else (Пропустить)
      |Система|
      :Завершает онбординг;
    endif
  else (Пропустить)
    |Система|
    :Завершает онбординг;
  endif

else (нет — существующий)
  :Показывает главное меню;
endif

' ==========================================
' ГЛАВНОЕ МЕНЮ
' ==========================================

|Пользователь|
:Главное меню;

fork

  :«Профиль»;
  |Система|
  if (Есть server_id?) then (да)
    :Получает client_data из 3x-ui;
    if (Подписка активна?) then (да)
      :Профиль + «Мой ключ»\n«Подключиться»;
    else (истекла)
      :Профиль + «Купить»\n«Триал» (если доступен);
    endif
  else (нет)
    :Профиль + «Купить»\n«Получить триал»;
  endif

fork again

  :«Подписка / Купить»;
  |Система|
  :Статус подписки + история транзакций;

  |Пользователь|
  if (Действие?) then (Купить / Продлить / Изменить)
    |Система|
    :Выбор кол-ва устройств;
    :Выбор длительности\n(цена из плана);
    :Создаёт Transaction PENDING\npayment_id = sbp_{uuid16};
    :Реквизиты СБП + кнопка «Я оплатил»;

    |Пользователь|
    :Нажимает «Я оплатил»;

    |Система|
    note right
      ⚠️ ИСПРАВЛЕНО:
      1) Валидация payment_id в БД
      2) Redis SET NX lock
      3) Кнопка убирается первой
    end note
    :Убирает кнопку «Я оплатил»;
    :Уведомляет администратора\n(payment_id + подтвердить/отклонить);

    |Администратор|
    if (Решение?) then (Подтвердить)
      |Система|
      :Активирует подписку через 3x-ui;
      :Transaction -> COMPLETED;
      :Реферальный бонус рефереру\n(если есть реферал + мин. дней);
      :Пользователю «Оплата принята»;
    else (Отклонить)
      |Система|
      :Transaction -> CANCELED;
      :Пользователю «Оплата отклонена»;
    endif
  else (Назад)
    |Система|
    :Возврат в главное меню;
  endif

fork again

  :«Рефералы»;
  |Система|
  :Реферальная ссылка\nhttps://t.me/{bot}?start={tg_id}\nСтатистика + сумма наград;

fork again

  :«Поддержка»;
  |Система|
  :Меню: Как подключиться /\nНе работает / Написать нам;

fork again

  :«Инструкции»;
  |Система|
  :Выбор платформы\n(iOS / Android / Windows);
  :Ссылка на скачивание +\ndeep-link для подключения;

end fork

|Пользователь|
stop

@enduml
